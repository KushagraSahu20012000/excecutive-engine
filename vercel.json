{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build --workspace client",
  "outputDirectory": "client/dist",
  "functions": {
    "api/[...route].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}