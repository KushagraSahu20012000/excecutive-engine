{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace client && rm -rf dist && cp -R client/dist dist",
  "outputDirectory": "dist",
  "functions": {
    "api/[...route].js": {
      "runtime": "nodejs22.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}