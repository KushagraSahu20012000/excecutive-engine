{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm --prefix client run build && rm -rf dist && mkdir -p dist && cp -R client/dist/. dist/",
  "outputDirectory": "dist",
  "functions": {
    "api/[...route].js": {
      "runtime": "nodejs22.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}